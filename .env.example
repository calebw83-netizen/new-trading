# Robinhood Crypto API key values. Keep this file as an example; put real values in .env.
ROBINHOOD_API_KEY=
ROBINHOOD_API_SECRET=

# paper: simulate order execution locally.
# live: use Robinhood Crypto, but execution still needs ROBINHOOD_ENABLE_LIVE_TRADING=true.
ROBINHOOD_MODE=paper
ROBINHOOD_ENABLE_LIVE_TRADING=false

# Trading guardrails.
ALLOWED_PRODUCTS=BTC-USD,ETH-USD,AAPL,NVDA,TSLA,SPY,QQQ
MAX_ORDER_QUOTE_USD=25
DAILY_QUOTE_LIMIT_USD=100
REQUIRE_CONFIRMATION=true

# Local audit database.
AUDIT_DB_PATH=trade_audit.sqlite3

# Internet news feeds used by Challenge Radar.
NEWS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://decrypt.co/feed,https://www.theblock.co/rss.xml,https://cryptoslate.com/feed/,https://news.bitcoin.com/feed/,https://bitcoinmagazine.com/.rss/full/,https://finance.yahoo.com/news/rssindex,https://feeds.a.dj.com/rss/RSSMarketsMain.xml,https://www.marketwatch.com/rss/topstories,https://www.cnbc.com/id/100003114/device/rss/rss.html
NEWS_TIMEOUT_SECONDS=8

# Auto scanner settings. Products are also constrained by ALLOWED_PRODUCTS.
SCAN_ASSET_CLASSES=crypto,stocks
SCAN_QUOTE_CURRENCY=USD
SCAN_MAX_PRODUCTS=12
SCAN_STOCK_SYMBOLS=AAPL,NVDA,TSLA,MSFT,AMZN,META,GOOGL,AMD,SPY,QQQ,IWM,COIN,MSTR,HOOD

# Disabled by default. When true, the Auto Execute button may execute proposals
# only after scan score is at least AUTO_EXECUTE_MIN_SCORE and guardrails pass.
AUTO_EXECUTE_ENABLED=false
AUTO_EXECUTE_MIN_SCORE=80
